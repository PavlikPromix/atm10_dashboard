generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Device {
  id            String    @id
  name          String
  tokenHash     String
  scriptVersion String?
  capabilities  Json?
  lastSeenAt    DateTime?
  online        Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  snapshots     Snapshot[]
  commands      CommandQueue[]
  resources     ResourceCurrent[]
  resourceSamples ResourceSample[]
  craftPatterns CraftPattern[]
}

model Snapshot {
  id        String   @id @default(cuid())
  deviceId  String
  payload   Json
  createdAt DateTime @default(now())
  device    Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId, createdAt])
}

model MetricPoint {
  id        String   @id @default(cuid())
  deviceId  String
  metric    String
  category  String?
  value     Float
  createdAt DateTime @default(now())

  @@index([deviceId, metric, createdAt])
}

model ResourceCurrent {
  id          String   @id @default(cuid())
  deviceId    String
  category    String
  resourceKey String
  name        String?
  displayName String?
  amount      Float
  unit        String?
  fingerprint String?
  nbtHash     String?
  craftable   Boolean  @default(false)
  lastRate    Float?
  payload     Json?
  firstSeenAt DateTime @default(now())
  lastChangedAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())
  updatedAt   DateTime @updatedAt
  device      Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@unique([deviceId, category, resourceKey])
  @@index([deviceId, category, amount])
  @@index([deviceId, category, lastRate])
  @@index([deviceId, category, displayName])
}

model ResourceSample {
  id          String   @id @default(cuid())
  deviceId    String
  category    String
  resourceKey String
  amount      Float
  createdAt   DateTime @default(now())
  device      Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId, category, resourceKey, createdAt])
  @@index([deviceId, category, createdAt])
}

model CraftPattern {
  id           String   @id @default(cuid())
  deviceId     String
  category     String
  resourceKey  String
  outputName   String?
  displayName  String?
  outputAmount Float    @default(1)
  ingredients  Json?
  payload      Json
  lastSeenAt   DateTime @default(now())
  updatedAt    DateTime @updatedAt
  device       Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@unique([deviceId, category, resourceKey])
  @@index([deviceId, category, displayName])
}

model AutocraftRule {
  id        String   @id @default(cuid())
  index     Int
  label     String?
  enabled   Boolean  @default(true)
  source    String?
  target    String?
  payload   Json
  updatedAt DateTime @updatedAt

  @@unique([index])
}

model CommandQueue {
  id          String    @id @default(cuid())
  deviceId    String
  action      String
  payload     Json
  status      String    @default("queued")
  result      String?
  requestedBy String?
  createdAt   DateTime  @default(now())
  sentAt      DateTime?
  ackedAt     DateTime?
  device      Device    @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId, status, createdAt])
}

model AlertEvent {
  id        String   @id @default(cuid())
  deviceId  String
  severity  String
  text      String
  createdAt DateTime @default(now())

  @@index([deviceId, createdAt])
}

model AppConfig {
  key       String   @id
  value     Json
  version   Int      @default(1)
  updatedAt DateTime @updatedAt
}
